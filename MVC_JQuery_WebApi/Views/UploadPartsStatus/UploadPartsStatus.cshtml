@using SharedCRCMS.Service
@{
    ViewBag.Title = @StandartLibrary.Lang.Resources.Download_Parts_Status_5636;
}

<div class="row">
    <div class="col-md-12">

        <div id="dropzoneBox" class="dropzone" style="margin-top:0px;margin-bottom:10px;width:100%;min-height:50px;height:50px;padding:0px;"></div>
    </div>
</div>

@section Scripts{

    <script>
        Dropzone.autoDiscover = false;

        var myDropzone = new Dropzone("#dropzoneBox", {
            url: "/UploadPartsStatus/UploadPartsStatus",
            acceptedFiles: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
        });
        myDropzone.on("addedfile", function (file) {
            if (this.files[1] != null) {
                this.removeFile(this.files[0]);
            }
        });
        myDropzone.on("success", function (file, responseText) {

        });
    </script>
}